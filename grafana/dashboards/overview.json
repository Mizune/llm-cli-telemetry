{
  "uid": "llm-overview",
  "title": "LLM Telemetry Overview",
  "description": "Overview of all LLM CLI tools telemetry",
  "tags": ["llm-telemetry"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service_name",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Tools",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(count by (service_name) (count_over_time({service_name=~\".+\"}[$__range])))",
          "legendFormat": "Tools",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Tokens (Claude Code + Gemini)",
      "description": "Token usage from Claude Code and Gemini CLI",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(claude_code_token_usage_tokens_total) + sum(gen_ai_client_token_usage_sum{service_name=\"gemini-cli\"}) or sum(claude_code_token_usage_tokens_total) or sum(gen_ai_client_token_usage_sum{service_name=\"gemini-cli\"})",
          "legendFormat": "Tokens"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null },
              { "color": "orange", "value": 10000 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short"
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Events",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=~\"$service_name\"}[$__range])",
          "legendFormat": "Events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Activity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Token Usage (Claude Code)",
      "description": "Token metrics emitted by Claude Code",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Token Usage (Gemini CLI)",
      "description": "Token metrics from Gemini CLI (gen_ai semantic conventions)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (gen_ai_token_type) (rate(gen_ai_client_token_usage_sum{service_name=\"gemini-cli\"}[5m]))",
          "legendFormat": "{{gen_ai_token_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Codex CLI Events",
      "description": "Event rate derived from Codex CLI logs via count connector",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event_name) (rate(codex_events_total[5m]))",
          "legendFormat": "{{event_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Recent Events",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent Events",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=~\"$service_name\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
