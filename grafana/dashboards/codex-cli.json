{
  "uid": "codex-cli",
  "title": "Codex CLI",
  "description": "OpenAI Codex CLI telemetry – logs, traces, and derived metrics",
  "tags": ["llm-telemetry", "codex-cli"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Events",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=\"codex_exec\"}[$__range])",
          "legendFormat": "Events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API Requests",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=\"codex_exec\"} |= \"api_request\" [$__range])",
          "legendFormat": "API Requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tool Decisions",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count_over_time({service_name=\"codex_exec\"} |= \"tool_decision\" [$__range])",
          "legendFormat": "Tool Decisions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "orange", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["sum"] } }
    },
    {
      "id": 5,
      "type": "row",
      "title": "Events",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Events Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event_name) (rate(codex_events_total[5m]))",
          "legendFormat": "{{event_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "normal" }
          },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] } }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Traces",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "traces",
      "title": "Trace Explorer",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "queryType": "traceql",
          "query": "{resource.service.name = \"codex_exec\"}",
          "limit": 20,
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Event Logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"codex_exec\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
